<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AutoSplit_AutoMask"
        x:Class="AutoSplit_AutoMask.PresetEditor"
        Title="Preset Editor" Height="720" Width="960"
        CanResize="False" FontSize="12"
        Background="#2C2C2C">

<Window.Styles>
        <Style Selector="TextBox">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="SelectionBrush" Value="#4D9ECA"/>
            <Setter Property="SelectionForegroundBrush" Value="White"/>
        </Style>
        <Style Selector="AutoCompleteBox">
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="Background" Value="#363636"/>
        </Style>
        <Style Selector="TextBox.Invalid">
            <Setter Property="BorderBrush" Value="#CC3333"/>
        </Style>
        <Style Selector="ListBox">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="MinHeight" Value="0"/>
        </Style>
        <Style Selector="ListBox.SplitsList ListBoxItem">
            <Setter Property="Padding" Value="6,6"/>
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="#1C3A58"/>
        </Style>
        <Style Selector="ListBoxItem.Dirty /template/ ContentPresenter">
            <Setter Property="Background" Value="#3A2800"/>
        </Style>
        <Style Selector="ListBoxItem.Dirty:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="#5A3C00"/>
        </Style>
        <Style Selector="ListBoxItem.GroupHover /template/ ContentPresenter">
            <Setter Property="Background" Value="#303030"/>
        </Style>
        <Style Selector="NumericUpDown">
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="Background" Value="#363636"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="CheckBox">
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Padding" Value="6,0,0,0"/>
        </Style>
    </Window.Styles>

    <DockPanel Margin="8">

        <!-- Bottom action bar -->
        <Border DockPanel.Dock="Bottom" BorderBrush="#444444" BorderThickness="0,1,0,0" Padding="0,8,0,0" Margin="0,8,0,0">
            <Grid>
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left">
                    <Button Name="BtnSave" Content="Save" Click="BtnSave_Click" Width="80"/>
                    <Button Name="BtnSaveAll" Content="Save All" Click="BtnSaveAll_Click" Width="80"/>
                    <Button Name="BtnSaveAsNew" Content="Save As New Preset..." Click="BtnSaveAsNew_Click" Width="160"/>
                </StackPanel>
                <Button Content="Close" Click="BtnClose_Click" Width="80" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <!-- Main two-panel layout: preset list | preset editor -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: preset list -->
            <DockPanel Grid.Column="0">
                <Button DockPanel.Dock="Bottom" Content="New Preset" Click="BtnNewPreset_Click"
                        Margin="0,6,0,0" HorizontalAlignment="Stretch"/>
                <Border BorderBrush="#444444" BorderThickness="1">
                    <ListBox Name="PresetListBox" SelectionChanged="PresetListBox_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="local:PresetDisplayItem">
                                <Grid>
                                    <!-- Group header row -->
                                    <Grid IsVisible="{Binding IsHeader}"
                                          ColumnDefinitions="*,5,Auto"
                                          Cursor="Hand" Margin="4,4,0,2">
                                        <TextBlock Grid.Column="0" Text="{Binding GroupName}"
                                                   FontWeight="SemiBold" FontSize="11"
                                                   Foreground="#AAAAAA" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding CollapseArrow}"
                                                   FontSize="10" Foreground="#AAAAAA"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                    <!-- Preset row -->
                                    <Grid IsVisible="{Binding !IsHeader}">
                                        <Rectangle Fill="#CC8800" Width="3" HorizontalAlignment="Left"
                                                   IsVisible="{Binding IsDirty}"/>
                                        <StackPanel Spacing="1" Margin="6,2,0,2">
                                            <TextBlock Text="{Binding PresetName}"/>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding SplitCount, StringFormat='{}Splits: {0}'}" FontSize="10" Foreground="#888888"/>
                                                <TextBlock Text="{Binding TotalImages, StringFormat='{}Total images: {0}'}" FontSize="10" Foreground="#888888"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </DockPanel>

            <!-- Divider -->
            <Border Grid.Column="1" BorderBrush="#444444" BorderThickness="1,0,0,0" Margin="3,0"/>

            <!-- Right: preset editor -->
            <DockPanel Grid.Column="2">

                <!-- Preset metadata -->
                <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Preset Name:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox Grid.Column="1" Name="PresetNameBox" Height="24" TextChanged="PresetNameBox_TextChanged"/>
                    <TextBlock Grid.Column="3" Text="Game Name:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <AutoCompleteBox Grid.Column="4" Name="GameNameBox" Height="24"
                                     FilterMode="Contains"
                                     TextChanged="GameNameBox_TextChanged"/>
                </Grid>

                <!-- Splits editor: list | form -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Splits list + toolbar -->
                    <DockPanel Grid.Column="0">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="4" Margin="0,0,0,4">
                            <Button Name="BtnAddSplit" Content="+" Width="39" Height="24" IsEnabled="False" Click="BtnAddSplit_Click" ToolTip.Tip="Add split after selected"/>
                            <Button Name="BtnRemoveSplit" Content="-" Width="39" Height="24" IsEnabled="False" Click="BtnRemoveSplit_Click" ToolTip.Tip="Remove selected split"/>
                            <Button Name="BtnDuplicateSplit" Content="⧉" Width="40" Height="24" IsEnabled="False" Click="BtnDuplicateSplit_Click" ToolTip.Tip="Duplicate selected split"/>
                            <Button Name="BtnImportSplits" Content="📥" Width="40" Height="24" IsEnabled="False" Click="BtnImportSplits_Click" ToolTip.Tip="Import pre-made splits"/>
                        </StackPanel>
                        <Border BorderBrush="#444444" BorderThickness="1">
                            <ListBox Name="SplitsListBox" Classes="SplitsList" SelectionChanged="SplitsListBox_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="local:SplitDisplayItem">
                                        <TextBlock Text="{Binding DisplayText}"
                                                   Opacity="{Binding Opacity}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </DockPanel>

                    <!-- Divider -->
                    <Border Grid.Column="1" BorderBrush="#444444" BorderThickness="1,0,0,0" Margin="3,0"/>

                    <!-- Split property form -->
                    <DockPanel Grid.Column="2">

                    <!-- Image previews -->
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8"
                                Margin="6,8,0,0">
                        <StackPanel Spacing="4" VerticalAlignment="Bottom">
                            <TextBlock Text="Mask preview" Foreground="#888888" FontSize="11"/>
                            <Border Name="MaskPreviewBorder" BorderBrush="#444444" BorderThickness="1"
                                    Background="#151515" Width="252" Height="189">
                                <Grid>
                                    <TextBlock Name="MaskPreviewError"
                                               Text="Failed to load image"
                                               Foreground="#CC4444"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               IsVisible="False"/>
                                    <Image Name="MaskPreviewImage" Stretch="Uniform"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="Output preview" Foreground="#888888" FontSize="11" VerticalAlignment="Center"/>
                                <Button Name="BtnClearBaseImage" Content="Clear" FontSize="10"
                                        Height="16" Padding="4,0" IsEnabled="False"
                                        Click="BtnClearBaseImage_Click"/>
                            </StackPanel>
                            <Border Name="OutputPreviewBorder" BorderBrush="#444444" BorderThickness="1"
                                    Background="#151515" Width="252" Height="189"
                                    Cursor="Hand" PointerPressed="OutputPreviewBorder_PointerPressed">
                                <Grid>
                                    <TextBlock Name="OutputPreviewHint"
                                               Text="Click to load base image"
                                               Foreground="#555555"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    <Image Name="OutputPreviewImage" Stretch="Uniform"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <Grid>
                    <TextBlock Name="NoSplitSelectedHint"
                               Text="Select a split to edit it"
                               Foreground="#666666"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               IsVisible="True"/>
                    <ScrollViewer Name="SplitFormScrollViewer" VerticalScrollBarVisibility="Auto" IsVisible="False">
                        <StackPanel Name="SplitFormPanel" Spacing="6" Margin="6,0,0,0">

                            <TextBlock Text="Name:"/>
                            <TextBox Name="SplitNameBox" Height="24" TextChanged="SplitNameBox_TextChanged"/>
                            <TextBlock Name="FilenamePreviewLabel" FontSize="11" Foreground="#888888"
                                       TextTrimming="CharacterEllipsis" Margin="0,-2,0,0"/>

                            <TextBlock Text="Mask image:"/>
                            <Grid ColumnDefinitions="*,6,Auto">
                                <TextBox Grid.Column="0" Name="SplitMaskBox" Height="24" IsReadOnly="True"/>
                                <Button Grid.Column="2" Content="Browse..." Height="24" Click="BtnBrowseMask_Click"/>
                            </Grid>

                            <TextBlock Text="Savestate file:"/>
                            <Grid ColumnDefinitions="*,6,Auto,6,Auto">
                                <TextBox Grid.Column="0" Name="SplitSavestateBox" Height="24" IsReadOnly="True"/>
                                <Button Grid.Column="2" Content="Browse..." Height="24" Click="BtnBrowseSavestate_Click"/>
                                <Button Grid.Column="4" Content="Clear" Height="24" Click="BtnClearSavestate_Click"/>
                            </Grid>

                            <StackPanel Name="SavestateInstructionsPanel" Spacing="6" IsVisible="False">
                                <TextBlock Text="Savestate instructions:"/>
                                <TextBox Name="SplitSavestateInstructionsBox"
                                         AcceptsReturn="True" TextWrapping="Wrap"
                                         MinHeight="60" MaxHeight="103"
                                         VerticalContentAlignment="Top"
                                         TextChanged="SplitSavestateInstructionsBox_TextChanged"/>
                            </StackPanel>

                            <Border BorderBrush="#444444" BorderThickness="1" CornerRadius="3" Padding="10,0">
                                <Grid ColumnDefinitions="Auto,8,60,8,*">
                                    <CheckBox Grid.Column="0" Name="SplitThresholdEnabledCheck" Content="Threshold"
                                              IsCheckedChanged="SplitThresholdEnabledCheck_IsCheckedChanged"/>
                                    <TextBox Grid.Column="2" Name="SplitThresholdBox" Height="24"
                                             IsEnabled="{Binding #SplitThresholdEnabledCheck.IsChecked}"
                                             TextChanged="SplitThresholdBox_TextChanged"
                                             LostFocus="SplitThresholdBox_LostFocus"/>
                                    <Slider Grid.Column="4" Name="SplitThresholdSlider"
                                            Minimum="0" Maximum="1" SmallChange="0.01" LargeChange="0.05"
                                            IsEnabled="{Binding #SplitThresholdEnabledCheck.IsChecked}"
                                            VerticalAlignment="Center"
                                            ValueChanged="SplitThresholdSlider_ValueChanged"/>
                                </Grid>
                            </Border>

                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <!-- Pause time box -->
                                <Border BorderBrush="#444444" BorderThickness="1" CornerRadius="3" Padding="10,4">
                                    <Grid ColumnDefinitions="Auto,5,Auto,3,Auto">
                                        <CheckBox Grid.Column="0" Name="SplitPauseTimeEnabledCheck" Content="Pause"
                                                  IsCheckedChanged="SplitPauseTimeEnabledCheck_IsCheckedChanged"/>
                                        <TextBox Grid.Column="2" Name="SplitPauseTimeBox" Width="55" Height="24"
                                                 IsEnabled="{Binding #SplitPauseTimeEnabledCheck.IsChecked}"
                                                 TextChanged="SplitPauseTimeBox_TextChanged"
                                                 LostFocus="SplitPauseTimeBox_LostFocus"/>
                                        <TextBlock Grid.Column="4" Text="s" VerticalAlignment="Center" Foreground="#888888"
                                                   IsEnabled="{Binding #SplitPauseTimeEnabledCheck.IsChecked}"/>
                                    </Grid>
                                </Border>

                                <!-- Delay box -->
                                <Border BorderBrush="#444444" BorderThickness="1" CornerRadius="3" Padding="10,4">
                                    <Grid ColumnDefinitions="Auto,5,Auto,4,Auto">
                                        <CheckBox Grid.Column="0" Name="SplitDelayEnabledCheck" Content="Delay"
                                                  IsCheckedChanged="SplitDelayEnabledCheck_IsCheckedChanged"/>
                                        <TextBox Grid.Column="2" Name="SplitDelayBox" Width="55" Height="24"
                                                 IsEnabled="{Binding #SplitDelayEnabledCheck.IsChecked}"
                                                 TextChanged="SplitDelayBox_TextChanged"
                                                 LostFocus="SplitDelayBox_LostFocus"/>
                                        <TextBlock Grid.Column="4" Text="ms" VerticalAlignment="Center" Foreground="#888888"
                                                   IsEnabled="{Binding #SplitDelayEnabledCheck.IsChecked}"/>
                                    </Grid>
                                </Border>

                                <!-- Dummy box -->
                                <Border BorderBrush="#444444" BorderThickness="1" CornerRadius="3" Padding="10,4">
                                    <CheckBox Name="SplitDummyCheck" Content="Dummy"
                                              IsCheckedChanged="SplitDummyCheck_IsCheckedChanged"/>
                                </Border>

                                <!-- Inverted box -->
                                <Border BorderBrush="#444444" BorderThickness="1" CornerRadius="3" Padding="10,4">
                                    <CheckBox Name="SplitInvertedCheck" Content="Inverted"
                                              IsCheckedChanged="SplitInvertedCheck_IsCheckedChanged"/>
                                </Border>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                    </Grid>

                    </DockPanel>

                </Grid>
            </DockPanel>

        </Grid>
    </DockPanel>
</Window>
