<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AutoSplit_AutoMask"
        x:Class="AutoSplit_AutoMask.MainWindow"
        x:DataType="local:MainWindow"
        CanResize="False"
        Title="AutoMask for AutoSplit" Height="426" Width="696" FontSize="12"
        Background="#2C2C2C">
    <Window.DataTemplates>
        <DataTemplate DataType="{x:Type local:PresetGroupHeader}">
            <TextBlock Text="{Binding GameName}" FontWeight="SemiBold" FontSize="11"
                       Foreground="#999999" Margin="0,1,0,1"/>
        </DataTemplate>
    </Window.DataTemplates>

    <DockPanel>

    <!-- Status bar -->
    <Border DockPanel.Dock="Bottom" BorderBrush="#484848" BorderThickness="0,1,0,0"
            Background="#252525" Padding="10,4">
        <TextBlock Name="ImageSavedLabel" Foreground="#22CC22" Opacity="0"
                   FontFamily="Consolas" FontSize="11"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis"/>
    </Border>

    <Grid Margin="12,8" RowDefinitions="Auto,8,Auto,4,Auto,8,Auto,8,Auto"
          ColumnDefinitions="328,16,328">

        <!-- Row 0: Toolbar (spans all columns) -->
        <Grid Grid.Row="0" Grid.Column="0"
              ColumnDefinitions="*,8,Auto,8,Auto">
            <Button Grid.Column="0" Name="BtnLoadInputImage" Content="Load base image(s)"
                    HorizontalContentAlignment="Center" Height="28" HorizontalAlignment="Stretch"
                    Click="BtnLoadInputImages_Click"/>
            <Button Grid.Column="2" Content="Show output"
                    HorizontalContentAlignment="Center" Height="28"
                    Click="BtnShowOutput_Click"/>
            <Button Grid.Column="4" Name="BtnOpenOutputFolder" Content="Live tester"
                    HorizontalContentAlignment="Center" Height="28"
                    Click="BtnOpenTestOutput_Click"/>
            
        </Grid>
        <Grid Grid.Row="0" Grid.Column="2"
              ColumnDefinitions="*,Auto">
            <ComboBox Grid.Column="0" Name="ComboBoxSelectPreset" Height="28"
                      HorizontalAlignment="Stretch" CornerRadius="4,0,0,4" Margin="0,0,-1,0"
                      ItemsSource="{Binding presetComboBoxItems}"
                      SelectionChanged="ComboBoxSelectPreset_SelectionChanged">
                <ComboBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type local:PresetComboItem}">
                        <StackPanel Spacing="1">
                            <TextBlock Text="{Binding PresetName}"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding SplitCount, StringFormat='{}Splits: {0}'}" FontSize="10" Foreground="#888888"/>
                                <TextBlock Text="{Binding TotalImages, StringFormat='{}Total images: {0}'}" FontSize="10" Foreground="#888888"/>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <Button Grid.Column="1" Name="BtnOpenPresetEditor" Content="Edit"
                    HorizontalContentAlignment="Center" Width="45" Height="28"
                    CornerRadius="0,4,4,0"
                    Click="BtnOpenPresetEditor_Click"/>
        </Grid>

            <!-- Row 2: Preview labels -->
        <TextBlock Grid.Row="2" Grid.Column="0" Name="InputImageLabel"
                   Text="Input image preview" TextAlignment="Center"/>
        <TextBlock Grid.Row="2" Grid.Column="2" Name="PreviewImageLabel"
                   Text="Output image preview" TextAlignment="Center"/>

        <!-- Row 3: Image previews (320x240 pixel-perfect) -->
        <Panel Grid.Row="4" Grid.Column="0">
            <Border BorderBrush="#484848" BorderThickness="1" Background="#151515" Padding="3"
                    Width="328" Height="248">
                <Image Name="InputImageView" Stretch="Uniform"
                       RenderOptions.BitmapInterpolationMode="None"/>
            </Border>
            <Border Name="InputLoadingOverlay" Background="#99000000" IsVisible="False"
                    Width="328" Height="248">
                <TextBlock Text="Loading..." HorizontalAlignment="Center"
                           VerticalAlignment="Center" Foreground="White"/>
            </Border>
        </Panel>

        <Panel Grid.Row="4" Grid.Column="2">
            <Border Name="OutputImageBorder" BorderBrush="#484848" BorderThickness="1"
                    Padding="3" Background="#151515" Width="328" Height="248"
                    PointerPressed="OutputImageBorder_PointerPressed">
                <Grid Background="Transparent">
                    <Border Name="OutputDarkBg" Background="#151515"/>
                    <Image Name="OutputCheckerBg" Stretch="Fill" IsVisible="False"/>
                    <Image Name="OutputImageView" Stretch="Uniform"
                           RenderOptions.BitmapInterpolationMode="None"/>
                </Grid>
            </Border>
            <Border Name="OutputLoadingOverlay" Background="#99000000" IsVisible="False"
                    Width="328" Height="248">
                <TextBlock Name="OutputLoadingText" Text="Loading..." HorizontalAlignment="Center"
                           VerticalAlignment="Center" Foreground="White"/>
            </Border>
        </Panel>

        <!-- Row 5: Base image/split selection -->
        <Grid Grid.Row="6" Grid.Column="0" ColumnDefinitions="Auto,*,Auto">
            <Button Grid.Column="0" Name="BtnInputImagePrev" Content="&lt;"
                    HorizontalContentAlignment="Center" Width="28" Height="28"
                    CornerRadius="4,0,0,4" Margin="0,0,-1,0"
                    IsEnabled="False" Click="BtnPrevInputImage_Click"/>
            <ComboBox Grid.Column="1" Name="ComboBoxSelectInputImage" Height="28"
                      HorizontalAlignment="Stretch" CornerRadius="0" Margin="0,0,-1,0"
                      IsEnabled="False" ItemsSource="{Binding inputImagesComboBoxItems}"
                      PlaceholderText="No base images loaded"
                      SelectionChanged="ComboBoxSelectInputImage_OnSelectionChanged">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="local:InputImageItem">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="{Binding FileName}" VerticalAlignment="Center"/>
                            <Image Grid.Column="1" Source="{Binding Thumbnail}"
                                   Width="32" Height="24" Stretch="Uniform" Margin="6,0,0,0"/>
                        </Grid>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <Button Grid.Column="2" Name="BtnInputImageNext" Content="&gt;"
                    HorizontalContentAlignment="Center" Width="28" Height="28"
                    CornerRadius="0,4,4,0"
                    IsEnabled="False" Click="BtnNextInputImage_Click"/>
        </Grid>

        <Grid Grid.Row="6" Grid.Column="2" ColumnDefinitions="Auto,*,Auto">
            <Button Grid.Column="0" Name="BtnPrevAlphaImage" Content="&lt;"
                    HorizontalContentAlignment="Center" Width="28" Height="28"
                    CornerRadius="4,0,0,4" Margin="0,0,-1,0"
                    IsEnabled="False" Click="BtnPrevAlphaImage_Click"/>
            <ComboBox Grid.Column="1" Name="ComboBoxSelectSplit" Height="28"
                      HorizontalAlignment="Stretch" CornerRadius="0" Margin="0,0,-1,0"
                      SelectedIndex="{Binding selectedSplitIndex}"
                      ItemsSource="{Binding splitsComboBoxItems}"
                      SelectionChanged="ComboBoxSelectSplit_OnSelectionChanged"/>
            <Button Grid.Column="2" Name="BtnNextAlphaImage" Content="&gt;"
                    HorizontalContentAlignment="Center" Width="28" Height="28"
                    CornerRadius="0,4,4,0"
                    IsEnabled="False" Click="BtnNextAlphaImage_Click"/>
        </Grid>

        <!-- Row 7: Output controls -->
        <Grid Grid.Row="8" Grid.Column="0" ColumnDefinitions="Auto,*">
            <Button Grid.Column="0" Content="🖿" Height="28" Width="28" Padding="0, 4, 0, 0"
                    HorizontalContentAlignment="Center"
                    CornerRadius="4,0,0,4" Margin="0,0,-1,0"
                    ToolTip.Tip="Set output folder"
                    Click="BtnSelectOutputDirectory_Click"/>
            <TextBox Grid.Column="1" Name="OutputDirectoryTextBox" Height="28"
                     IsReadOnly="True" Focusable="False" IsHitTestVisible="False"
                     PlaceholderText="No output folder selected"
                     VerticalContentAlignment="Center" CornerRadius="0,4,4,0"
                     BorderBrush="#565656"/>
        </Grid>

        <Grid Grid.Row="8" Grid.Column="2" ColumnDefinitions="*,8,Auto,8,Auto">
            <Button Name="BtnSave" Content="Save output" Grid.Column="0" HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center" Height="28"
                    Click="BtnAutoSave_Click"/>
            <Button Name="BtnSaveAs" Content="Save as..." Grid.Column="2"
                    HorizontalContentAlignment="Center" Height="28"
                    Click="BtnSaveImageAs_Click"/>
            <Button Name="BtnSaveAllSplits" Content="Save all" Grid.Column="4"
                    HorizontalContentAlignment="Center" Height="28"
                    Click="BtnSaveAllSplits_Click"/>
        </Grid>
    </Grid>

    </DockPanel>
</Window>
