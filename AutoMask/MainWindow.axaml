<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AutoSplit_AutoMask.MainWindow"
        CanResize="False"
        Title="AutoMask for AutoSplit" Height="506" Width="836" FontSize="12"
        Background="#2C2C2C">
    <Window.Resources>
        <!-- ComboBox hover/focus brushes -->
        <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver" Color="#3C3C3C"/>
        <SolidColorBrush x:Key="ComboBoxBorderBrushPointerOver" Color="#565656"/>
        <SolidColorBrush x:Key="ComboBoxBackgroundPressed" Color="#3C3C3C"/>
        <SolidColorBrush x:Key="ComboBoxBorderBrushPressed" Color="#565656"/>
        <!-- TextBox hover/focus brushes -->
        <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#3C3C3C"/>
        <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#565656"/>
        <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#3C3C3C"/>
        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#565656"/>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="ComboBox">
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="Background" Value="#363636"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="ComboBoxItem">
            <Setter Property="Padding" Value="8,2"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="Background" Value="#363636"/>
        </Style>
    </Window.Styles>

    <Grid Margin="8,2,8,2">

        <!-- Row 1: toolbar -->
        <!-- Left side (x=10..402) aligns with left image; right side (x=418..810) aligns with right image -->
        <Button HorizontalContentAlignment="Center" Name="BtnLoadInputImage" Content="Load input image(s)" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10,12,0,0" Width="152" Height="28" Click="BtnLoadInputImages_Click" />
        <Button HorizontalContentAlignment="Center" Content="Show output" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="170,12,0,0" Width="107" Height="28" Click="BtnShowOutput_Click" />
        <Button HorizontalContentAlignment="Center" Name="BtnOpenOutputFolder" Content="Show presets" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="285,12,0,0" Width="117" Height="28" Click="BtnOpenPresetsFolder_Click" />
        <ComboBox Name="ComboBoxSelectPreset" Width="323" Height="28" ItemsSource="{Binding presetComboBoxItems}" SelectedIndex="{Binding selectedPresetIndex}" SelectionChanged="ComboBoxSelectPreset_SelectionChanged" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="418,12,0,0" />
        <Button HorizontalContentAlignment="Center" Name="BtnRefreshPresets" Content="Refresh" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="749,12,0,0" Width="61" Height="28" Click="BtnRefreshPresets_Click" />

        <!-- Row 2: preview labels -->
        <TextBlock Text="Input image preview" Name="InputImageLabel" Width="392" HorizontalAlignment="Left" VerticalAlignment="Top" TextAlignment="Center" Margin="10,52,0,0" />
        <TextBlock Text="Output image preview" Name="PreviewImageLabel" Width="392" HorizontalAlignment="Left" VerticalAlignment="Top" TextAlignment="Center" Margin="418,52,0,0" />

        <!-- Row 3: image previews -->
        <!-- Containers are 392x296: internal 384x288 = 4:3, leaving 4px padding on each side -->
        <Border BorderBrush="#484848" BorderThickness="1" Width="392" Height="296" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,72,0,0" Background="#151515" Padding="3">
            <Image Name="InputImageView" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Stretch="Uniform" />
        </Border>
        <Border Name="OutputImageBorder" BorderBrush="#484848" BorderThickness="1" Width="392" Height="296" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="418,72,0,0" Padding="3" Background="#151515" PointerPressed="OutputImageBorder_PointerPressed">
            <Grid Background="Transparent">
                <Border Name="OutputDarkBg" Background="#151515"/>
                <Image Name="OutputCheckerBg" Stretch="Fill" IsVisible="False"/>
                <Image Name="OutputImageView" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Stretch="Uniform"/>
            </Grid>
        </Border>
        <TextBlock Foreground="Green" Opacity="0" Name="ImageSavedLabel" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,466,0,0" Width="400" TextTrimming="CharacterEllipsis" />
        <Border Name="InputLoadingOverlay" Width="392" Height="296" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,72,0,0" Background="#99000000" IsVisible="False">
            <TextBlock Text="Loading..." HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
        </Border>
        <Border Name="OutputLoadingOverlay" Width="392" Height="296" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="418,72,0,0" Background="#99000000" IsVisible="False">
            <TextBlock Text="Loading..." HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
        </Border>

        <!-- Row 4: image / split navigation -->
        <Button HorizontalContentAlignment="Center" Name="BtnInputImagePrev" IsEnabled="False" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10,380,0,0" Width="28" Height="28" Click="BtnNextInputImage_Click">&lt;</Button>
        <ComboBox Name="ComboBoxSelectInputImage" SelectionChanged="ComboBoxSelectInputImage_OnSelectionChanged" ItemsSource="{Binding inputImagesComboBoxItems}" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="42,380,0,0" Width="328" Height="28">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding FileName}" VerticalAlignment="Center"/>
                        <Image Grid.Column="1" Source="{Binding Thumbnail}" Width="32" Height="24" Stretch="Uniform" Margin="6,0,0,0"/>
                    </Grid>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
        <Button HorizontalContentAlignment="Center" Name="BtnInputImageNext" IsEnabled="False" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="374,380,0,0" Width="28" Height="28" Click="BtnPrevInputImage_Click">&gt;</Button>

        <Button HorizontalContentAlignment="Center" Name="BtnPrevAlphaImage" IsEnabled="False" Content="&lt;" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="418,380,0,0" Width="28" Height="28" Click="BtnNextAlphaImage_Click" />
        <ComboBox Name="ComboBoxSelectSplit" SelectionChanged="ComboBoxSelectSplit_OnSelectionChanged" SelectedIndex="{Binding selectedSplitIndex}" ItemsSource="{Binding splitsComboBoxItems}" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="450,380,0,0" Width="328" Height="28" />
        <Button HorizontalContentAlignment="Center" Name="BtnNextAlphaImage" IsEnabled="False" Content="&gt;" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="782,380,0,0" Width="28" Height="28" Click="BtnPrevAlphaImage_Click" />

        <!-- Row 5: output directory + save buttons -->
        <Button HorizontalContentAlignment="Center" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10,420,0,0" Width="92" Height="28" Click="BtnSelectOutputDirectory_Click" Content="Set output" />
        <TextBox Name="OutputDirectoryTextBox" Width="296" Height="28" HorizontalAlignment="Left" VerticalAlignment="Top" IsReadOnly="True" Focusable="True" Margin="106,420,0,0" VerticalContentAlignment="Center" />
        <Button HorizontalContentAlignment="Center" Name="BtnLoadCustomAlphaImage" Content="Load custom mask" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="418,420,0,0" Width="144" Height="28" Click="BtnLoadAlphaImage_Click" />
        <Button HorizontalContentAlignment="Center" Name="BtnSave" Content="Save masked image" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="566,420,0,0" Width="152" Height="28" Click="BtnAutoSave_Click" />
        <Button HorizontalContentAlignment="Center" Name="BtnSaveAs" Content="Save as..." VerticalAlignment="Top" HorizontalAlignment="Left" Margin="722,420,0,0" Width="88" Height="28" Click="BtnSaveImageAs_Click" />

        <!--
        <Button HorizontalContentAlignment="Center" Width="130" Height="28" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10,404,0,0" Click="BtnOpenPresetEditor_Click">
            Open preset editor
        </Button>
        -->
        
        <Button HorizontalContentAlignment="Center" Name="BtnSaveAllSplits" Content="Save all split images" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="418, 460, 0, 0" Width="392" Click="BtnSaveAllSplits_Click"/>

    </Grid>
</Window>
