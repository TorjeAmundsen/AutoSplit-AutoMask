<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>WinExe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <DebugType Condition="'$(Configuration)' == 'Release'">none</DebugType>
        <CopyOutputSymbolsToPublishDirectory>false</CopyOutputSymbolsToPublishDirectory>
        <RootNamespace>AutoSplit_AutoMask</RootNamespace>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <SelfContained>true</SelfContained>
        <PublishAot>true</PublishAot>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
        <NoWarn>$(NoWarn);AVLN3001</NoWarn>
        <ApplicationIcon>Assets/icon.ico</ApplicationIcon>
        <Version>0.9.2-alpha</Version>
        <IncludeSourceRevisionInInformationalVersion>false</IncludeSourceRevisionInInformationalVersion>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Avalonia" Version="12.0.1" />
        <PackageReference Include="Avalonia.Desktop" Version="12.0.1" />
        <PackageReference Include="Avalonia.Themes.Fluent" Version="12.0.1" />
        <PackageReference Include="Avalonia.Fonts.Inter" Version="12.0.1" />
        <PackageReference Include="Avalonia.Diagnostics" Version="11.3.14" Condition="'$(Configuration)' == 'Debug'" />
        <PackageReference Include="SkiaSharp" Version="3.119.3-preview.1.1" />
        <PackageReference Include="SkiaSharp.NativeAssets.Linux" Version="3.119.3-preview.1.1" />
        <PackageReference Include="OpenCvSharp4" Version="4.10.0.20240616" Condition="'$(Configuration)' == 'Debug'" />
        <PackageReference Include="OpenCvSharp4.runtime.win" Version="4.10.0.20240616" Condition="'$(Configuration)' == 'Debug'" />
    </ItemGroup>

    <ItemGroup>
      <AvaloniaResource Include="Assets/icon.ico" />
      <None Remove="presets\**\*" />
      <Content Include="presets\**\*">
        <CopyToOutputDirectory>Always</CopyToOutputDirectory>
      </Content>
      <None Remove="splits\**\*" />
      <Content Include="splits\**\*">
        <CopyToOutputDirectory>Always</CopyToOutputDirectory>
      </Content>
    </ItemGroup>

    <ItemGroup>
      <Compile Update="ImportSplitsDialog.axaml.cs">
        <DependentUpon>ImportSplitsDialog.axaml</DependentUpon>
      </Compile>
      <Compile Update="PresetEditor.axaml.cs">
        <DependentUpon>PresetEditor.axaml</DependentUpon>
      </Compile>
      <Compile Update="MainWindow.axaml.cs">
        <DependentUpon>MainWindow.axaml</DependentUpon>
      </Compile>
      <Compile Update="TestOutputWindow.axaml.cs">
        <DependentUpon>TestOutputWindow.axaml</DependentUpon>
      </Compile>
      <Compile Update="SavestateInstructionsWindow.axaml.cs">
        <DependentUpon>SavestateInstructionsWindow.axaml</DependentUpon>
      </Compile>
    </ItemGroup>

    <!-- Live tester (TestOutputWindow + Capture/*) depends on OpenCV and is
         only shipped in Debug builds. Keeping the tester code compiled in
         Release would force OpenCV native libs into the output. -->
    <ItemGroup Condition="'$(Configuration)' == 'Release'">
      <Compile Remove="Capture\**\*.cs" />
      <Compile Remove="TestOutputWindow.axaml.cs" />
      <AvaloniaResource Remove="TestOutputWindow.axaml" />
      <AvaloniaXaml Remove="TestOutputWindow.axaml" />
      <Page Remove="TestOutputWindow.axaml" />
      <None Include="TestOutputWindow.axaml" />
    </ItemGroup>
</Project>
